{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developer.api.oclc.org/schemas/worldcat-holding.json",
  "title": "InstitutionHolding",
  "description": "WorldCat InstitutionHolding schema",
